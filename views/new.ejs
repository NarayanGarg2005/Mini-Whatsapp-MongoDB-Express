<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New chat</title>
</head>
<body>
    <h3>Add new chat</h3>
    <form method="POST" action="/chats">
        Sender Name: 
        <input type="text" name="from">
        <br><br>
        Receiver Name:
        <input type="text" name="to">
        <br><br>
        <textarea name="msg" id="msg" rows="10" cols="35" placeholder="Write your message here..."></textarea>
        <br><br>
        <button>Send</button>
    </form>
</body>
</html>